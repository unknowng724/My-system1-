{
  "name": "استمارة إدخال البيانات المحدثة",
  "short_name": "الاستمارة",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#0e1d3e",
  "theme_color": "#0e1d3e",
  "icons": [
    {
      "src": "logo1.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "logo1.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "logo1.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "shared_file",
          "accept": ["image/*", "text/*", "application/*"]
        }
      ]
    }
  },
  "features": {
    "hardware_support": "basic"
  }
}
